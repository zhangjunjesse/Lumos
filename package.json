{
  "name": "lumos",
  "version": "0.20.12",
  "private": true,
  "author": {
    "name": "op7418",
    "email": "7418@openclaw.ai"
  },
  "description": "A native desktop GUI client for Claude Code",
  "main": "dist-electron/main.js",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "jest",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "ci:verify": "npm run typecheck && npm run build",
    "ci:verify:strict": "npm run lint -- --max-warnings=0 && npm run typecheck && npm run build",
    "hooks:install": "node scripts/install-git-hooks.mjs",
    "prepare": "node scripts/install-git-hooks.mjs",
    "electron:dev": "cross-env LUMOS_CLAUDE_CONFIG_DIR=$HOME/.lumos/.claude LUMOS_DATA_DIR=$HOME/.lumos concurrently -k \"next dev\" \"node scripts/build-electron.mjs && wait-on http://localhost:3000 && electron .\"",
    "electron:build": "node scripts/download-node.mjs && node scripts/download-git-bash.mjs && next build && node scripts/build-electron.mjs",
    "electron:pack": "npm run electron:build && electron-builder --config electron-builder.yml",
    "electron:pack:mac": "npm run electron:build && electron-builder --mac --config electron-builder.yml",
    "electron:pack:win": "npm run electron:build && electron-builder --win --config electron-builder.yml",
    "electron:pack:linux": "npm run electron:build && electron-builder --linux --config electron-builder.yml"
  },
